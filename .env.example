# The launcher sets the API URL automatically. These values document the defaults.
HAWORTHIA_API_URL=http://127.0.0.1:8000/api
HAWORTHIA_DB_PATH=haworthia_omics.db
HAWORTHIA_IMAGE_DIR=local_images
HAWORTHIA_MODEL_PATH=model_base.pth
HAWORTHIA_CHECKPOINT_PATH=checkpoint_base.pth

# Directory containing isnet-general-use.onnx and u2net.onnx.
# Windows example: C:\Users\your-name\.u2net
U2NET_HOME=~/.u2net
